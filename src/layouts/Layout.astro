---
import WhatsAppButton from '../components/WhatsAppButton.astro';

export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'TechAfrik Quantum Group — Secure. Connect. Protect.',
  description = 'Mission-critical surveillance, secure connectivity, advanced cybersecurity, and intelligent fleet management — from Africa to the world.',
} = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en" dir="ltr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href={`${base}icon.svg`} type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+Arabic:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <div id="page-bg" aria-hidden="true"></div>
  <canvas id="particles-canvas" aria-hidden="true"></canvas>
  <slot />
  <WhatsAppButton />
  <script>
    if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
    window.scrollTo(0, 0);
  </script>
  <script>
    import '../scripts/nav.js';
  </script>
  <script>
    import '../scripts/hscroll.js';
  </script>
  <script>
    import '../scripts/i18n.js';
  </script>
  <script>
    import '../scripts/section-bg.js';
  </script>
  <script>
    import '../scripts/bg-engine.js';
  </script>
  <script>
    import '../scripts/globe.js';
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
