---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Assets Management — TechAfrik" description="GPS fleet tracking, fuel level monitoring, and driver behavior analytics for operational visibility and loss prevention.">
  <Nav />
  <main id="main">

    <section id="hero" class="sol-hero">
      <div class="container sol-hero__inner">
        <p class="section-label">What We Build</p>
        <h1 class="sol-hero__title">Assets Management</h1>
        <p class="sol-hero__lead lead">Full visibility over your fleet, equipment, and fuel — in real time. We integrate GPS tracking, fuel monitoring, and driver analytics systems that give operators the data they need to cut losses, prevent theft, and improve safety compliance.</p>
      </div>
    </section>

    <section id="capabilities" class="sol-caps">
      <div class="container">
        <p class="section-label">Capabilities</p>

        <div class="cap-row">
          <div class="cap-row__text">
            <h2 class="cap-row__title">GPS Fleet Tracking & Geofencing</h2>
            <p class="cap-row__body">Real-time GPS positioning for vehicles, trailers, and mobile equipment — accessible via web and mobile dashboard. Geofencing rules trigger automatic alerts when assets enter or exit defined zones, enabling rapid response to unauthorized movement or route deviations.</p>
            <ul class="cap-row__list">
              <li>Continuous real-time vehicle location updates</li>
              <li>Historical route playback and stop analysis</li>
              <li>Virtual geofence creation with entry/exit alerts</li>
              <li>Battery and solar-powered trackers for unpowered assets and trailers</li>
              <li>Multi-fleet map view with live status indicators</li>
            </ul>
          </div>
          <div class="cap-row__media">
            <div class="media-slot"><span class="media-slot__label">Video / Image</span></div>
          </div>
        </div>

        <div class="cap-row">
          <div class="cap-row__text">
            <h2 class="cap-row__title">Fuel Level Monitoring & Consumption Analytics</h2>
            <p class="cap-row__body">Fuel level sensors connected to fleet management software provide real-time visibility into tank levels, consumption rates, and refueling events. Analytics identify wasteful idling, abnormal consumption patterns, and potential unauthorized fuel drainage.</p>
            <ul class="cap-row__list">
              <li>Real-time fuel level readings from in-tank sensors</li>
              <li>Consumption analytics per vehicle, route, and time period</li>
              <li>Refueling event detection, logging, and reconciliation</li>
              <li>Idle time monitoring and fuel waste reporting</li>
              <li>Alerts on abnormal drain rates or unauthorized siphoning activity</li>
            </ul>
          </div>
          <div class="cap-row__media">
            <div class="media-slot"><span class="media-slot__label">Video / Image</span></div>
          </div>
        </div>

        <div class="cap-row cap-row--last">
          <div class="cap-row__text">
            <h2 class="cap-row__title">Driver Behavior & Safety Scoring</h2>
            <p class="cap-row__body">AI-powered in-cab and external cameras combined with vehicle telematics automatically detect and score driver behavior events. Fleet managers receive automated safety reports, and drivers receive real-time in-cab coaching to correct unsafe habits before incidents occur.</p>
            <ul class="cap-row__list">
              <li>Detection of harsh braking, acceleration, and cornering</li>
              <li>Distracted driving and fatigue detection via AI camera systems</li>
              <li>Automated per-driver safety scoring and fleet-wide ranking</li>
              <li>Real-time in-cab audio alerts for unsafe driving events</li>
              <li>Video clip upload for incident review and liability documentation</li>
            </ul>
          </div>
          <div class="cap-row__media">
            <div class="media-slot"><span class="media-slot__label">Video / Image</span></div>
          </div>
        </div>

      </div>
    </section>

    <section id="contact" class="sol-cta">
      <div class="container sol-cta__inner">
        <h2 class="sol-cta__title">Looking to improve fleet performance?</h2>
        <p class="sol-cta__body lead">Tell us about your fleet size and operational environment — we'll recommend the right tracking and monitoring architecture.</p>
        <a class="btn btn--primary" href={`${base}#contact`}>Contact Us</a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .sol-hero {
    min-height: 60vh;
    display: flex; align-items: center;
    padding: clamp(120px, 14vw, 180px) 0 clamp(48px, 6vw, 80px);
  }
  .sol-hero__title {
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 800; letter-spacing: -.04em;
    color: var(--text); text-transform: uppercase; line-height: 1;
    margin: 12px 0 clamp(20px, 3vw, 36px);
  }
  .sol-hero__lead { max-width: 640px; font-style: italic; }

  .sol-caps { padding-bottom: clamp(80px, 10vw, 140px); }
  .sol-caps .section-label {
    margin-top: clamp(24px, 3vw, 40px);
    margin-bottom: clamp(32px, 4vw, 56px);
  }

  .cap-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 4vw, 64px);
    align-items: center;
    padding: clamp(40px, 5vw, 72px) 0;
    border-top: 1px solid var(--border);
  }
  .cap-row--last { border-bottom: 1px solid var(--border); }

  .cap-row__title {
    font-size: clamp(18px, 1.8vw, 24px);
    font-weight: 800;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: -.02em;
    line-height: 1.1;
    margin-bottom: clamp(12px, 1.5vw, 18px);
  }
  .cap-row__body {
    font-size: clamp(14px, 1.2vw, 16px);
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: clamp(16px, 1.8vw, 24px);
  }
  .cap-row__list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 8px;
  }
  .cap-row__list li {
    font-size: clamp(13px, 1.1vw, 15px);
    color: var(--text);
    line-height: 1.5;
  }

  .media-slot {
    aspect-ratio: 16 / 9;
    border: 1px dashed rgba(255,255,255,0.15);
    border-radius: 4px;
    background: rgba(255,255,255,0.02);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }
  .media-slot__label {
    font-size: 11px;
    font-weight: 600;
    color: rgba(255,255,255,0.2);
    text-transform: uppercase;
    letter-spacing: .2em;
  }

  @media (max-width: 768px) {
    .cap-row { grid-template-columns: 1fr; }
  }

  .sol-cta {
    padding: clamp(48px, 6vw, 80px) 0;
    border-top: 1px solid var(--border);
  }
  .sol-cta__inner { display: flex; flex-direction: column; gap: 16px; }
  .sol-cta__title {
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 800; letter-spacing: -.04em;
    color: var(--text); text-transform: uppercase; line-height: 1;
  }
  .sol-cta__body { max-width: 560px; }
</style>
