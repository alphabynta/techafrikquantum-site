---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Cybersecurity — TechAfrik" description="Vulnerability assessment, SOC onboarding, and IAM implementation for organisations operating in the West African threat landscape.">
  <script is:inline>document.body.dataset.pageBg='#f5f0e8';document.body.dataset.pageTone='light';</script>
  <Nav />
  <main id="main">

    <section id="sol-hero" class="sol-hero">
      <div class="container sol-hero__inner">
        <h1 class="sol-hero__title">Cybersecurity</h1>
        <p class="sol-hero__lead lead">Protecting your networks, endpoints, and identities against real-world threats. We design and implement cybersecurity architectures — from initial assessment through SOC operations — adapted to the West African threat landscape and your compliance requirements.</p>
      </div>
    </section>

    <section id="capabilities" class="sol-caps">
      <div class="container">
        <details class="cap-item">
          <summary class="cap-item__trigger">
            <span class="cap-item__title">Vulnerability Assessment &amp; Penetration Testing</span>
            <span class="cap-item__icon">+</span>
          </summary>
          <div class="cap-item__body">
            <div class="cap-item__text">
              <p class="cap-item__desc">We conduct structured security assessments to identify vulnerabilities in your network infrastructure, applications, and endpoints before adversaries do. Findings are delivered with clear risk ratings and actionable remediation roadmaps tailored to your operational context.</p>
              <ul class="cap-item__list">
                <li>Network infrastructure vulnerability scanning and assessment</li>
                <li>Web application and API penetration testing</li>
                <li>Social engineering and phishing simulation exercises</li>
                <li>Wireless network security assessment</li>
                <li>Detailed findings report with prioritised remediation plan</li>
              </ul>
            </div>
            <div class="cap-item__media">
              <div class="media-slot"><span class="media-slot__label">Video / Image</span></div>
            </div>
          </div>
        </details>

        <details class="cap-item">
          <summary class="cap-item__trigger">
            <span class="cap-item__title">SOC Onboarding &amp; 24/7 Threat Monitoring</span>
            <span class="cap-item__icon">+</span>
          </summary>
          <div class="cap-item__body">
            <div class="cap-item__text">
              <p class="cap-item__desc">We design, configure, and onboard Security Operations Centre environments — integrating your infrastructure into a SIEM platform, building detection rules aligned to the MITRE ATT&CK framework, and standing up 24/7 monitoring. For organisations that need fully managed coverage, we operate the SOC on their behalf.</p>
              <ul class="cap-item__list">
                <li>SIEM platform deployment and log source integration</li>
                <li>Detection rule development aligned to MITRE ATT&CK</li>
                <li>Endpoint Detection and Response (EDR) deployment</li>
                <li>24/7 alert triage, investigation, and incident response</li>
                <li>Security metrics, SLA reporting, and continuous tuning</li>
              </ul>
            </div>
            <div class="cap-item__media">
              <div class="media-slot"><span class="media-slot__label">Video / Image</span></div>
            </div>
          </div>
        </details>

        <details class="cap-item cap-item--last">
          <summary class="cap-item__trigger">
            <span class="cap-item__title">IAM, Zero-Trust &amp; Compliance Frameworks</span>
            <span class="cap-item__icon">+</span>
          </summary>
          <div class="cap-item__body">
            <div class="cap-item__text">
              <p class="cap-item__desc">We implement identity and access management systems that enforce least-privilege access across your organisation — on-premise and in the cloud. We also guide organisations through the compliance frameworks applicable to their sector, regulatory environment, and contractual obligations.</p>
              <ul class="cap-item__list">
                <li>Active Directory and cloud identity provider configuration</li>
                <li>Multi-factor authentication (MFA) rollout and policy enforcement</li>
                <li>Role-based and attribute-based access control (RBAC/ABAC)</li>
                <li>Zero-trust network access (ZTNA) architecture and implementation</li>
                <li>Compliance alignment: ISO 27001, NIST CSF, and sector-specific frameworks</li>
              </ul>
            </div>
            <div class="cap-item__media">
              <div class="media-slot"><span class="media-slot__label">Video / Image</span></div>
            </div>
          </div>
        </details>

      </div>
    </section>

    <section id="sol-cta" class="sol-cta">
      <div class="container sol-cta__inner">
        <h2 class="sol-cta__title">Need to assess your security posture?</h2>
        <p class="sol-cta__body lead">Tell us about your infrastructure and compliance requirements — we'll propose an assessment and roadmap.</p>
        <a class="btn btn--primary" href={`${base}#contact`}>Contact Us</a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .sol-hero {
    min-height: 60vh;
    display: flex; align-items: center;
    padding: clamp(120px, 14vw, 180px) 0 clamp(48px, 6vw, 80px);
  }
  .sol-hero__title {
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 800; letter-spacing: -.04em;
    color: var(--accent); text-transform: uppercase; line-height: 1; text-align: center;
    margin: 12px 0 clamp(20px, 3vw, 36px);
  }
  .sol-hero__lead { max-width: 640px; font-style: italic; }

  .sol-caps { padding-bottom: clamp(80px, 10vw, 140px); }
  .sol-caps .section-label {
    margin-top: clamp(24px, 3vw, 40px);
    margin-bottom: clamp(8px, 1vw, 16px);
  }

  .cap-item { border-top: 1px solid var(--border); }
  .cap-item--last { border-bottom: 1px solid var(--border); }

  .cap-item__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: clamp(20px, 2.5vw, 28px) 0;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .cap-item__trigger::-webkit-details-marker { display: none; }

  .cap-item__title {
    font-size: clamp(16px, 1.6vw, 22px);
    font-weight: 800;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: -.02em;
    line-height: 1.1;
  }

  .cap-item__icon {
    font-size: 22px;
    font-weight: 300;
    color: var(--accent);
    flex-shrink: 0;
    margin-left: 24px;
    transition: transform 0.3s ease;
    line-height: 1;
  }
  details[open] .cap-item__icon { transform: rotate(45deg); }

  .cap-item__body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 4vw, 64px);
    align-items: start;
    padding-bottom: clamp(32px, 4vw, 52px);
  }

  .cap-item__desc {
    font-style: italic;
    font-size: clamp(14px, 1.2vw, 16px);
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: clamp(16px, 1.8vw, 24px);
  }

  .cap-item__list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 8px;
  }
  .cap-item__list li {
    font-size: clamp(13px, 1.1vw, 15px);
    color: var(--text);
    line-height: 1.5;
  }

  .media-slot {
    aspect-ratio: 16 / 9;
    border: 1px dashed rgba(255,255,255,0.15);
    border-radius: 4px;
    background: rgba(255,255,255,0.02);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }
  .media-slot__label {
    font-size: 11px;
    font-weight: 600;
    color: rgba(255,255,255,0.2);
    text-transform: uppercase;
    letter-spacing: .2em;
  }

  @media (max-width: 768px) {
    .cap-item__body { grid-template-columns: 1fr; }
  }

  .sol-cta {
    padding: clamp(48px, 6vw, 80px) 0;
    border-top: 1px solid var(--border);
  }
  .sol-cta__inner { display: flex; flex-direction: column; gap: 16px; }
  .sol-cta__title {
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 800; letter-spacing: -.04em;
    color: var(--text); text-transform: uppercase; line-height: 1;
  }
  .sol-cta__body { max-width: 560px; }
</style>
