---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Connectivity — TechAfrik" description="Mission-critical connectivity solutions — satellite links, SOTM, SOTP, and microwave backhaul for remote and mobile operations.">
  <Nav />
  <main id="main">

    <section id="hero" class="sol-hero">
      <div class="container sol-hero__inner">
        <p class="section-label">What We Build</p>
        <h1 class="sol-hero__title">Connectivity</h1>
        <p class="sol-hero__lead lead">When your operation cannot afford downtime, we engineer redundant, multi-path connectivity solutions — from satellite links to microwave backhaul — designed for mission-critical environments.</p>
      </div>
    </section>

    <section id="capabilities" class="sol-caps">
      <div class="container">
        <p class="section-label">Capabilities</p>
        <div class="caps-grid">

          <div class="cap-card">
            <h2 class="cap-card__title">Sites Interconnection over Satellite</h2>
            <p class="cap-card__body">We connect isolated and distributed sites using VSAT and LEO satellite links. High-availability configurations with redundant beam paths ensure connectivity even in degraded conditions.</p>
            <ul class="cap-card__list">
              <li>VSAT C/Ku/Ka-band for fixed remote sites</li>
              <li>LEO broadband (Starlink, OneWeb) for rapid deployment</li>
              <li>Dual-path failover between satellite and terrestrial</li>
            </ul>
          </div>

          <div class="cap-card">
            <h2 class="cap-card__title">Satellite on the Move (SOTM)</h2>
            <p class="cap-card__body">Continuous satellite connectivity for vehicles, vessels, and aircraft in motion. SOTM systems maintain a live link to the satellite while the platform moves, enabling real-time command, control, and communications on the go.</p>
            <ul class="cap-card__list">
              <li>Auto-tracking antennas for ground vehicles & vessels</li>
              <li>Seamless beam handover during movement</li>
              <li>Encrypted voice, data & video over mobile link</li>
            </ul>
          </div>

          <div class="cap-card">
            <h2 class="cap-card__title">Satellite on the Pause (SOTP)</h2>
            <p class="cap-card__body">Rapidly deployable satellite terminals that establish connectivity when a vehicle or unit stops. SOTP systems are designed for quick setup and teardown — ideal for mobile command posts and field operations.</p>
            <ul class="cap-card__list">
              <li>Rapid-deploy flyaway & manpack terminals</li>
              <li>Auto-acquisition for fast setup on arrival</li>
              <li>Compatible with military & commercial satellite networks</li>
            </ul>
          </div>

          <div class="cap-card">
            <h2 class="cap-card__title">Site-to-Site Microwave Links</h2>
            <p class="cap-card__body">For urban, peri-urban, and campus environments, we design and deploy licensed microwave backhaul links. Low latency, high throughput, and no dependency on third-party last-mile providers.</p>
            <ul class="cap-card__list">
              <li>Licensed microwave point-to-point (PtP) links</li>
              <li>Point-to-multipoint (PtMP) for multi-site clusters</li>
              <li>RF site surveys, frequency planning & licensing support</li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <section id="contact" class="sol-cta">
      <div class="container sol-cta__inner">
        <h2 class="sol-cta__title">Need reliable connectivity?</h2>
        <p class="sol-cta__body lead">Tell us about your environment and we'll design a solution around your constraints.</p>
        <a class="btn btn--primary" href={`${base}#contact`}>Contact Us</a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .sol-hero {
    min-height: 60vh;
    display: flex; align-items: center;
    padding: clamp(120px, 14vw, 180px) 0 clamp(48px, 6vw, 80px);
  }
  .sol-hero__title {
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 800; letter-spacing: -.04em;
    color: var(--text); text-transform: uppercase; line-height: 1;
    margin: 12px 0 clamp(20px, 3vw, 36px);
  }
  .sol-hero__lead { max-width: 640px; font-style: italic; }

  .sol-caps { padding-bottom: clamp(80px, 10vw, 140px); }
  .caps-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: clamp(24px, 3vw, 40px);
  }
  @media (max-width: 600px) { .caps-grid { grid-template-columns: 1fr; } }

  .cap-card {
    border: 1px solid var(--border);
    border-top: 3px solid var(--accent);
    background: rgba(255,255,255,0.03);
    padding: clamp(24px, 2.5vw, 36px);
    border-radius: 4px;
    display: flex; flex-direction: column; gap: 14px;
    transition: background 0.2s ease;
  }
  .cap-card:hover { background: rgba(255,255,255,0.06); }
  .cap-card__title {
    font-size: clamp(16px, 1.5vw, 20px);
    font-weight: 800; color: var(--accent);
    text-transform: uppercase; letter-spacing: -.02em; line-height: 1.1;
  }
  .cap-card__body {
    font-size: clamp(14px, 1.2vw, 16px);
    color: var(--muted); line-height: 1.7;
  }
  .cap-card__list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 8px;
  }
  .cap-card__list li {
    font-size: clamp(13px, 1.1vw, 15px);
    color: var(--text);
    padding-left: 16px; position: relative; line-height: 1.5;
  }
  .cap-card__list li::before {
    content: '—';
    position: absolute; left: 0;
    color: var(--accent); font-weight: 700;
  }

  .sol-cta {
    padding: clamp(48px, 6vw, 80px) 0;
    border-top: 1px solid var(--border);
  }
  .sol-cta__inner { display: flex; flex-direction: column; gap: 16px; }
  .sol-cta__title {
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 800; letter-spacing: -.04em;
    color: var(--text); text-transform: uppercase; line-height: 1;
  }
  .sol-cta__body { max-width: 560px; }
</style>
