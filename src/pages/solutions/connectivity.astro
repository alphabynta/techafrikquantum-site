---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Connectivity — TechAfrik" description="Mission-critical connectivity — satellite, SOTM, manpacks, flyaway, driveaway, tactical HUBs, microwave, and radio for remote and mobile operations.">
  <Nav />
  <main id="main">

    <section id="hero" class="sol-hero">
      <div class="container sol-hero__inner">
        <h1 class="sol-hero__title">Connectivity</h1>
        <p class="sol-hero__lead lead">When your operation cannot afford downtime, we engineer redundant, multi-path connectivity solutions — from geo-redundant satellite hubs to microwave backhaul and tactical radio — designed for mission-critical environments anywhere on the continent.</p>
      </div>
    </section>

    <section id="capabilities" class="sol-caps">
      <div class="container">
        <details class="cap-item">
          <summary class="cap-item__trigger">
            <span class="cap-item__title">Sites Interconnection over Satellite</span>
            <span class="cap-item__icon">+</span>
          </summary>
          <div class="cap-item__body">
            <div class="cap-item__text">
              <p class="cap-item__desc">We connect isolated and distributed sites using VSAT and broadband satellite links. High-availability configurations with geo-redundant satellite HUBs — dual ground station architecture with automatic failover between geographically separated teleports — ensure connectivity even when one hub is degraded or unavailable.</p>
              <ul class="cap-item__list">
                <li>VSAT C/Ku/Ka-band links for fixed and remote sites</li>
                <li>LEO broadband for rapid-deployment and high-throughput scenarios</li>
                <li>Geo-redundant satellite HUBs with automatic teleport failover</li>
                <li>Dual-path failover between satellite and terrestrial backups</li>
                <li>Unified IP link carrying voice, data, and video</li>
              </ul>
            </div>
            <div class="cap-item__media">
              <div class="media-slot"><span class="media-slot__label">Video / Image</span></div>
            </div>
          </div>
        </details>

        <details class="cap-item">
          <summary class="cap-item__trigger">
            <span class="cap-item__title">Satellite on the Move (SOTM)</span>
            <span class="cap-item__icon">+</span>
          </summary>
          <div class="cap-item__body">
            <div class="cap-item__text">
              <p class="cap-item__desc">Continuous satellite connectivity for vehicles, vessels, and mobile platforms in motion. SOTM systems maintain a live link to the satellite while the platform moves, enabling real-time command, control, and communications without interruption.</p>
              <ul class="cap-item__list">
                <li>Auto-tracking antennas for ground vehicles and naval vessels</li>
                <li>Seamless beam handover during movement</li>
                <li>Live voice, video, and data over a mobile satellite link</li>
                <li>Encrypted communications for sensitive operations</li>
                <li>Compatible with GEO and LEO satellite constellations</li>
              </ul>
            </div>
            <div class="cap-item__media">
              <div class="media-slot"><span class="media-slot__label">Video / Image</span></div>
            </div>
          </div>
        </details>

        <details class="cap-item">
          <summary class="cap-item__trigger">
            <span class="cap-item__title">Rapid-Deployment Satellite Terminals (SOTP)</span>
            <span class="cap-item__icon">+</span>
          </summary>
          <div class="cap-item__body">
            <div class="cap-item__text">
              <p class="cap-item__desc">Satellite terminals designed for fast setup and teardown — enabling connectivity wherever a unit or team stops. From man-portable kits to vehicle-integrated systems, these terminals auto-acquire the satellite on arrival and establish a link within minutes.</p>
              <ul class="cap-item__list">
                <li>Manpacks — man-portable terminals for dismounted and foot-mobile deployments</li>
                <li>Flyaway kits — airline-checkable case systems deployable anywhere within hours</li>
                <li>Driveaway systems — vehicle-integrated terminals with automatic satellite acquisition on arrival</li>
                <li>Fast auto-acquisition for immediate connectivity on setup</li>
                <li>Compatible with military and commercial satellite networks</li>
              </ul>
            </div>
            <div class="cap-item__media">
              <div class="media-slot"><span class="media-slot__label">Video / Image</span></div>
            </div>
          </div>
        </details>

        <details class="cap-item">
          <summary class="cap-item__trigger">
            <span class="cap-item__title">Tactical Communication HUBs</span>
            <span class="cap-item__icon">+</span>
          </summary>
          <div class="cap-item__body">
            <div class="cap-item__text">
              <p class="cap-item__desc">Field-deployable central nodes that aggregate multiple connectivity paths — satellite, microwave, and radio — onto a single managed IP backbone. Tactical HUBs serve as the communications anchor for forward operating bases, mobile command posts, and multi-site field operations.</p>
              <ul class="cap-item__list">
                <li>Aggregation of satellite, microwave, and radio links into a unified IP core</li>
                <li>Traffic prioritisation and quality of service for voice, video, and data</li>
                <li>Integration of MANET, VHF/UHF radio, and satellite onto one backbone</li>
                <li>Ruggedized and portable form factors for forward deployments</li>
                <li>Remote management and real-time status monitoring</li>
              </ul>
            </div>
            <div class="cap-item__media">
              <div class="media-slot"><span class="media-slot__label">Video / Image</span></div>
            </div>
          </div>
        </details>

        <details class="cap-item">
          <summary class="cap-item__trigger">
            <span class="cap-item__title">Site-to-Site Microwave Links</span>
            <span class="cap-item__icon">+</span>
          </summary>
          <div class="cap-item__body">
            <div class="cap-item__text">
              <p class="cap-item__desc">For urban, peri-urban, and campus environments, we design and deploy licensed microwave backhaul links. Low latency, high throughput, and no dependency on third-party last-mile providers — ideal for inter-site connectivity where terrestrial fiber is unavailable or uneconomical.</p>
              <ul class="cap-item__list">
                <li>Licensed microwave point-to-point (PtP) links</li>
                <li>Point-to-multipoint (PtMP) for multi-site clusters</li>
                <li>Encrypted microwave links for secure inter-site data</li>
                <li>RF site surveys, frequency planning, and licensing support</li>
                <li>High-availability configurations with automatic link protection</li>
              </ul>
            </div>
            <div class="cap-item__media">
              <div class="media-slot"><span class="media-slot__label">Video / Image</span></div>
            </div>
          </div>
        </details>

        <details class="cap-item">
          <summary class="cap-item__trigger">
            <span class="cap-item__title">Radio Communication</span>
            <span class="cap-item__icon">+</span>
          </summary>
          <div class="cap-item__body">
            <div class="cap-item__text">
              <p class="cap-item__desc">We design and deploy VHF/UHF radio networks for tactical and operational communications — from repeater infrastructure extending coverage across difficult terrain, to IP radio gateways bridging legacy radio networks into modern data architectures.</p>
              <ul class="cap-item__list">
                <li>VHF/UHF radio networks for tactical and field operations</li>
                <li>Encrypted digital voice (DMR, P25, TETRA) for public safety and defense</li>
                <li>Repeater infrastructure for coverage in terrain-challenged areas</li>
                <li>IP radio gateways bridging radio networks to data systems</li>
                <li>Integration with dispatch, command, and control center platforms</li>
              </ul>
            </div>
            <div class="cap-item__media">
              <div class="media-slot"><span class="media-slot__label">Video / Image</span></div>
            </div>
          </div>
        </details>

        <details class="cap-item cap-item--last">
          <summary class="cap-item__trigger">
            <span class="cap-item__title">Network Telemetry, SLA Monitoring &amp; NOC Support</span>
            <span class="cap-item__icon">+</span>
          </summary>
          <div class="cap-item__body">
            <div class="cap-item__text">
              <p class="cap-item__desc">All connectivity solutions we deploy are backed by continuous monitoring from a centralised Network Operations Centre. We provide proactive fault detection, SLA-based availability reporting, remote troubleshooting, and scheduled preventive maintenance — so your links stay up and performance stays measurable.</p>
              <ul class="cap-item__list">
                <li>24/7 network monitoring from a centralised NOC</li>
                <li>Proactive fault detection and alerting before outages impact operations</li>
                <li>SLA-based reporting on availability, latency, and throughput</li>
                <li>Remote troubleshooting and configuration management</li>
                <li>Scheduled preventive maintenance and on-site intervention</li>
              </ul>
            </div>
            <div class="cap-item__media">
              <div class="media-slot"><span class="media-slot__label">Video / Image</span></div>
            </div>
          </div>
        </details>

      </div>
    </section>

    <section id="contact" class="sol-cta">
      <div class="container sol-cta__inner">
        <h2 class="sol-cta__title">Need reliable connectivity?</h2>
        <p class="sol-cta__body lead">Tell us about your environment and we'll design a solution around your constraints.</p>
        <a class="btn btn--primary" href={`${base}#contact`}>Contact Us</a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .sol-hero {
    min-height: 60vh;
    display: flex; align-items: center;
    padding: clamp(120px, 14vw, 180px) 0 clamp(48px, 6vw, 80px);
  }
  .sol-hero__title {
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 800; letter-spacing: -.04em;
    color: var(--text); text-transform: uppercase; line-height: 1;
    margin: 12px 0 clamp(20px, 3vw, 36px);
  }
  .sol-hero__lead { max-width: 640px; font-style: italic; }

  .sol-caps { padding-bottom: clamp(80px, 10vw, 140px); }
  .sol-caps .section-label {
    margin-top: clamp(24px, 3vw, 40px);
    margin-bottom: clamp(8px, 1vw, 16px);
  }

  .cap-item { border-top: 1px solid var(--border); }
  .cap-item--last { border-bottom: 1px solid var(--border); }

  .cap-item__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: clamp(20px, 2.5vw, 28px) 0;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .cap-item__trigger::-webkit-details-marker { display: none; }

  .cap-item__title {
    font-size: clamp(16px, 1.6vw, 22px);
    font-weight: 800;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: -.02em;
    line-height: 1.1;
  }

  .cap-item__icon {
    font-size: 22px;
    font-weight: 300;
    color: var(--accent);
    flex-shrink: 0;
    margin-left: 24px;
    transition: transform 0.3s ease;
    line-height: 1;
  }
  details[open] .cap-item__icon { transform: rotate(45deg); }

  .cap-item__body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 4vw, 64px);
    align-items: start;
    padding-bottom: clamp(32px, 4vw, 52px);
  }

  .cap-item__desc {
    font-style: italic;
    font-size: clamp(14px, 1.2vw, 16px);
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: clamp(16px, 1.8vw, 24px);
  }

  .cap-item__list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 8px;
  }
  .cap-item__list li {
    font-size: clamp(13px, 1.1vw, 15px);
    color: var(--text);
    line-height: 1.5;
  }

  .media-slot {
    aspect-ratio: 16 / 9;
    border: 1px dashed rgba(255,255,255,0.15);
    border-radius: 4px;
    background: rgba(255,255,255,0.02);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }
  .media-slot__label {
    font-size: 11px;
    font-weight: 600;
    color: rgba(255,255,255,0.2);
    text-transform: uppercase;
    letter-spacing: .2em;
  }

  @media (max-width: 768px) {
    .cap-item__body { grid-template-columns: 1fr; }
  }

  .sol-cta {
    padding: clamp(48px, 6vw, 80px) 0;
    border-top: 1px solid var(--border);
  }
  .sol-cta__inner { display: flex; flex-direction: column; gap: 16px; }
  .sol-cta__title {
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 800; letter-spacing: -.04em;
    color: var(--text); text-transform: uppercase; line-height: 1;
  }
  .sol-cta__body { max-width: 560px; }
</style>
