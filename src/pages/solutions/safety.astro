---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Safety & Surveillance — TechAfrik" description="ISR drone integration, MANET networking, IP CCTV, and AI video analytics for mission-critical surveillance operations.">
  <Nav />
  <main id="main">

    <section id="hero" class="sol-hero">
      <div class="container sol-hero__inner">
        <p class="section-label">What We Build</p>
        <h1 class="sol-hero__title">Safety &amp; Surveillance</h1>
        <p class="sol-hero__lead lead">Total situational awareness — from the ground up and the air down. We design and integrate surveillance architectures that combine ISR drones, mesh networking, IP CCTV, and AI analytics into a unified operational picture.</p>
      </div>
    </section>

    <section id="capabilities" class="sol-caps">
      <div class="container">
        <p class="section-label">Capabilities</p>

        <div class="cap-row">
          <div class="cap-row__text">
            <h2 class="cap-row__title">ISR Drone Integration & Airspace Monitoring</h2>
            <p class="cap-row__body">We integrate unmanned aerial systems into your security architecture — providing persistent elevated surveillance, real-time aerial reconnaissance, and airspace monitoring. Tethered and free-flight platforms extend your surveillance perimeter beyond ground-based systems and feed live video into your command center.</p>
            <ul class="cap-row__list">
              <li>Tethered UAS for persistent elevated ISR without flight-time limits</li>
              <li>Autonomous free-flight drones for area reconnaissance and patrol</li>
              <li>Airspace monitoring and counter-UAS (C-UAS) RF detection</li>
              <li>Live video downlink integrated into command and control systems</li>
              <li>Vehicle-mounted and man-portable platform options</li>
            </ul>
          </div>
          <div class="cap-row__media">
            <div class="media-slot"><span class="media-slot__label">Video / Image</span></div>
          </div>
        </div>

        <div class="cap-row">
          <div class="cap-row__text">
            <h2 class="cap-row__title">Mobile Ad Hoc Networking Systems (MANET)</h2>
            <p class="cap-row__body">MANET radios form self-healing, self-configuring IP mesh networks that connect personnel, vehicles, and unmanned systems in the field — without relying on fixed infrastructure. Every node acts simultaneously as a transceiver and router, automatically adapting to movement and link disruptions.</p>
            <ul class="cap-row__list">
              <li>Self-forming mesh with no master node dependency</li>
              <li>Simultaneous voice, video, and data over a single encrypted IP link</li>
              <li>Integration with UAVs, UGVs, and sensor platforms</li>
              <li>Operational in GPS-denied and electronically contested environments</li>
              <li>Scalable from small team deployments to large multi-node networks</li>
            </ul>
          </div>
          <div class="cap-row__media">
            <div class="media-slot"><span class="media-slot__label">Video / Image</span></div>
          </div>
        </div>

        <div class="cap-row">
          <div class="cap-row__text">
            <h2 class="cap-row__title">IP CCTV & Thermal Imaging Networks</h2>
            <p class="cap-row__body">We design and deploy scalable IP video surveillance networks for perimeters, facilities, and urban environments. Fixed, PTZ, and thermal cameras are integrated into a unified video management system — accessible from a central command center or remotely over secure links.</p>
            <ul class="cap-row__list">
              <li>Fixed, PTZ, and multi-sensor camera deployments</li>
              <li>Long-range thermal cameras for perimeter detection in low-light and zero-light</li>
              <li>Ruggedized outdoor enclosures for harsh environments</li>
              <li>Edge and central recording with redundant storage options</li>
              <li>Integration with access control, alarm, and dispatch systems</li>
            </ul>
          </div>
          <div class="cap-row__media">
            <div class="media-slot"><span class="media-slot__label">Video / Image</span></div>
          </div>
        </div>

        <div class="cap-row cap-row--last">
          <div class="cap-row__text">
            <h2 class="cap-row__title">AI-Assisted Video Analytics & Alerting</h2>
            <p class="cap-row__body">AI-powered analytics engines process live and recorded video to detect threats, anomalies, and events automatically — reducing operator workload and shortening response time. Analytics run at the edge or centrally and integrate directly into your operations center workflow.</p>
            <ul class="cap-row__list">
              <li>Intrusion detection and perimeter breach alerting</li>
              <li>Person and vehicle detection, classification, and counting</li>
              <li>Behavioral anomaly and unusual motion detection</li>
              <li>Cross-camera person and vehicle search across large archives</li>
              <li>Alert correlation with access control and incident management platforms</li>
            </ul>
          </div>
          <div class="cap-row__media">
            <div class="media-slot"><span class="media-slot__label">Video / Image</span></div>
          </div>
        </div>

      </div>
    </section>

    <section id="contact" class="sol-cta">
      <div class="container sol-cta__inner">
        <h2 class="sol-cta__title">Need a surveillance architecture?</h2>
        <p class="sol-cta__body lead">Tell us about your environment and threat profile — we'll design a solution around your operational requirements.</p>
        <a class="btn btn--primary" href={`${base}#contact`}>Contact Us</a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .sol-hero {
    min-height: 60vh;
    display: flex; align-items: center;
    padding: clamp(120px, 14vw, 180px) 0 clamp(48px, 6vw, 80px);
  }
  .sol-hero__title {
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 800; letter-spacing: -.04em;
    color: var(--text); text-transform: uppercase; line-height: 1;
    margin: 12px 0 clamp(20px, 3vw, 36px);
  }
  .sol-hero__lead { max-width: 640px; font-style: italic; }

  .sol-caps { padding-bottom: clamp(80px, 10vw, 140px); }
  .sol-caps .section-label {
    margin-top: clamp(24px, 3vw, 40px);
    margin-bottom: clamp(32px, 4vw, 56px);
  }

  .cap-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 4vw, 64px);
    align-items: center;
    padding: clamp(40px, 5vw, 72px) 0;
    border-top: 1px solid var(--border);
  }
  .cap-row--last { border-bottom: 1px solid var(--border); }

  .cap-row__title {
    font-size: clamp(18px, 1.8vw, 24px);
    font-weight: 800;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: -.02em;
    line-height: 1.1;
    margin-bottom: clamp(12px, 1.5vw, 18px);
  }
  .cap-row__body {
    font-size: clamp(14px, 1.2vw, 16px);
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: clamp(16px, 1.8vw, 24px);
  }
  .cap-row__list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 8px;
  }
  .cap-row__list li {
    font-size: clamp(13px, 1.1vw, 15px);
    color: var(--text);
    line-height: 1.5;
  }

  .media-slot {
    aspect-ratio: 16 / 9;
    border: 1px dashed rgba(255,255,255,0.15);
    border-radius: 4px;
    background: rgba(255,255,255,0.02);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }
  .media-slot__label {
    font-size: 11px;
    font-weight: 600;
    color: rgba(255,255,255,0.2);
    text-transform: uppercase;
    letter-spacing: .2em;
  }

  @media (max-width: 768px) {
    .cap-row { grid-template-columns: 1fr; }
  }

  .sol-cta {
    padding: clamp(48px, 6vw, 80px) 0;
    border-top: 1px solid var(--border);
  }
  .sol-cta__inner { display: flex; flex-direction: column; gap: 16px; }
  .sol-cta__title {
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 800; letter-spacing: -.04em;
    color: var(--text); text-transform: uppercase; line-height: 1;
  }
  .sol-cta__body { max-width: 560px; }
</style>
