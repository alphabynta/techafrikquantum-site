---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import WhoWeAre from '../components/WhoWeAre.astro';
import Solutions from '../components/Solutions.astro';
import Partners from '../components/Partners.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
const base = import.meta.env.BASE_URL;
---
<Layout
  title="TechAfrik — Secure. Connect. Protect."
  description="Mission-critical surveillance, secure connectivity, advanced cybersecurity, and intelligent fleet management — from Africa to the world."
>
  <script is:inline>document.body.dataset.pageBg='transparent';document.body.dataset.pageTone='dark';</script>
  <video class="site-bg-video" src={`${base}videos/satellite.mp4`} autoplay muted loop playsinline aria-hidden="true"></video>
  <div class="site-bg-overlay" aria-hidden="true"></div>
  <Nav />
  <main id="main">
    <Hero />
    <WhoWeAre />
    <Solutions />
    <Partners />
    <Contact />
  </main>
  <Footer />
</Layout>

<style is:global>
  .site-bg-video {
    position: fixed;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    z-index: -4;
  }
  .site-bg-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.68);
    z-index: -3;
  }
  #particles-canvas { display: none; }
</style>
