---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---
<footer class="site-footer" role="contentinfo">
  <div class="container footer-strip">
    <a class="footer-logo" href={`${base}`} aria-label="TechAfrik home">
      <svg class="footer-logo-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 111 44" role="img" aria-label="TechAfrik logo">
        <rect x="0" y="16" width="51" height="20" fill="none" stroke="#f5a524" stroke-width="1.8"/>
        <g class="logo-tech-letters">
          <rect x="3"  y="19" width="10" height="2"/>
          <rect x="7"  y="21" width="2"  height="13"/>
          <rect x="15" y="19" width="2"  height="15"/>
          <rect x="17" y="19" width="8"  height="2"/>
          <rect x="17" y="26" width="6"  height="2"/>
          <rect x="17" y="32" width="8"  height="2"/>
          <rect x="27" y="19" width="2"  height="15"/>
          <rect x="29" y="19" width="8"  height="2"/>
          <rect x="29" y="32" width="8"  height="2"/>
          <rect x="39" y="19" width="2"  height="15"/>
          <rect x="47" y="19" width="2"  height="15"/>
          <rect x="41" y="26" width="6"  height="2"/>
        </g>
        <g stroke="#f5a524" stroke-width="1.6" fill="none" stroke-linejoin="miter">
          <!-- A -->
          <polyline points="55,34 59,22 63,34"/>
          <line x1="57" y1="29" x2="61" y2="29"/>
          <!-- F -->
          <polyline points="73,22 65,22 65,34"/>
          <line x1="65" y1="28" x2="72" y2="28"/>
          <!-- R -->
          <polyline points="75,34 75,22 83,22 83,28 75,28"/>
          <line x1="79" y1="28" x2="83" y2="34"/>
          <!-- I -->
          <line x1="89" y1="22" x2="89" y2="34"/>
          <line x1="85" y1="22" x2="93" y2="22"/>
          <line x1="85" y1="34" x2="93" y2="34"/>
          <!-- K -->
          <line x1="95" y1="22" x2="95" y2="34"/>
          <line x1="95" y1="28" x2="103" y2="22"/>
          <line x1="95" y1="28" x2="103" y2="34"/>
        </g>
        <line x1="55" y1="38" x2="101" y2="38" stroke="#f5a524" stroke-width="1.6"/>
        <polygon points="101,35 107,38 101,41" fill="#f5a524"/>
      </svg>
    </a>
    <p class="footer-copy" data-i18n="footer.copyright">
      &copy; {year} TechAfrik. All rights reserved.
    </p>
    <div class="footer-social">
      <a href="#" class="social-icon" aria-label="LinkedIn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
      </a>
      <a href="#" class="social-icon" aria-label="Twitter / X">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href="#" class="social-icon" aria-label="Facebook">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--nav-scrolled-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-top: 1px solid var(--border);
    overflow: visible;
  }
  .footer-strip {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; flex-wrap: wrap; height: 64px; overflow: visible;
  }
  .footer-logo { display: inline-flex; align-items: center; }
  .footer-logo-svg { width: clamp(110px, 14vw, 155px); height: auto; }
  .logo-tech-letters { fill: #ffffff; }
  :global([data-bg-tone="light"]) .logo-tech-letters { fill: #000000; }
  .footer-copy { font-size: 13px; color: var(--muted); margin: 0; }
  .footer-social { display: flex; gap: 8px; }
  .social-icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 32px; height: 32px; border-radius: 8px;
    border: 1px solid var(--border); color: var(--muted);
    transition: color .15s, border-color .15s;
  }
  .social-icon:hover { color: var(--text); border-color: rgba(255,255,255,.2); }
  @media (max-width: 480px) {
    .footer-strip { justify-content: center; text-align: center; }
  }
</style>
