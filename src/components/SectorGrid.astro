---
const base = import.meta.env.BASE_URL;
const sectors = [
  {
    num: '01', id: 'defense',
    titleKey: 'defense.title', bodyKey: 'defense.body',
    liKeys: ['defense.li1','defense.li2','defense.li3'],
    title: 'Defense',
    body: 'We deliver hardened surveillance, secure communications, and ISR capabilities for defense forces operating in challenging environments. Our solutions are designed for reliability under pressure — from perimeter protection to command-and-control connectivity.',
    li: ['Tactical surveillance & ISR drone integration','Encrypted military-grade communications','Rapid deployment & field-serviceable systems'],
  },
  {
    num: '02', id: 'government',
    titleKey: 'government.title', bodyKey: 'government.body',
    liKeys: ['government.li1','government.li2','government.li3'],
    title: 'Government',
    body: 'We support government agencies and public institutions with secure network infrastructure, surveillance systems, and digital governance tools.',
    li: ['Public safety & smart city infrastructure','Secure inter-agency communications','Governance, risk & compliance frameworks'],
  },
  {
    num: '03', id: 'enterprise',
    titleKey: 'enterprise.title', bodyKey: 'enterprise.body',
    liKeys: ['enterprise.li1','enterprise.li2','enterprise.li3'],
    title: 'Enterprise',
    body: 'Corporate networks, cybersecurity operations, and assets management for businesses that cannot afford downtime.',
    li: ['Enterprise network design & orchestration','SOC onboarding & IAM implementation','Fleet & assets tracking for operations'],
  },
  {
    num: '04', id: 'oilgas',
    titleKey: 'oilgas.title', bodyKey: 'oilgas.body',
    liKeys: ['oilgas.li1','oilgas.li2','oilgas.li3'],
    title: 'Oil & Gas',
    body: 'Remote sites, offshore platforms, and pipeline corridors demand connectivity and safety systems that work without exception.',
    li: ['Satellite & radio connectivity for remote sites','Perimeter intrusion detection for critical assets','Fleet tracking & fuel anti-fraud systems'],
  },
  {
    num: '05', id: 'cellular-mobility',
    titleKey: 'cellular.title', bodyKey: 'cellular.body',
    liKeys: ['cellular.li1','cellular.li2','mobility.li1','mobility.li2'],
    title: 'Cellular & Mobility',
    body: 'We partner with cellular operators on RF engineering and spectrum management, while helping transport operators and national fleets gain connectivity, reduce costs, and improve safety.',
    li: ['RF engineering & spectrum management','QoS & traffic engineering for carrier-grade networks','Real-time GPS fleet tracking & geofencing','Driver behavior scoring & safety compliance'],
  },
];
---

<div class="container sector-grid-wrap">
  <div class="sector-grid">
    {sectors.map((s) => (
      <div class="sec-card" id={s.id}>
        <span class="sec-card__num" aria-hidden="true">{s.num}</span>
        <div class="sec-card__inner">
          <h3 class="sec-card__title" data-i18n={s.titleKey}>{s.title}</h3>
          <p class="sec-card__body" data-i18n={s.bodyKey}>{s.body}</p>
          <ul class="sec-card__list">
            {s.li.map((text, j) => (
              <li data-i18n={s.liKeys[j]}>{text}</li>
            ))}
          </ul>
        </div>
      </div>
    ))}
  </div>
</div>

<style define:vars={{ droneUrl: `url('${base}icons/drone.svg')` }}>
  .sector-grid-wrap {
    padding-bottom: clamp(48px, 6vw, 80px);
  }

  .sector-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
  }

  /* Card */
  .sec-card {
    position: relative;
    overflow: hidden;
    background: rgba(255,255,255,0.02);
    border-left: 2px solid transparent;
    padding: 20px 18px;
    display: flex;
    flex-direction: column;
    gap: 0;
    transition: background 0.2s ease, border-color 0.2s ease;
    cursor: default;
  }
  .sec-card:hover {
    background: rgba(245, 165, 36, 0.05);
    border-left-color: var(--accent);
  }

  /* Watermark number */
  .sec-card__num {
    position: absolute;
    top: -4px; right: 10px;
    font-size: 52px;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.05em;
    color: rgba(245, 165, 36, 0.05);
    pointer-events: none;
    user-select: none;
    transition: color 0.2s ease;
  }
  .sec-card:hover .sec-card__num {
    color: rgba(245, 165, 36, 0.1);
  }

  .sec-card__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sec-card__title {
    font-size: 11px;
    font-weight: 800;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: .1em;
    line-height: 1;
  }

  .sec-card__body {
    font-size: 11px;
    color: var(--muted);
    line-height: 1.6;
  }

  .sec-card__list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 5px;
    margin-top: 2px;
  }
  .sec-card__list li {
    font-size: 10px;
    color: var(--muted);
    padding-left: 16px; position: relative;
    line-height: 1.4;
  }
  .sec-card__list li::before {
    content: '';
    position: absolute; left: 0; top: 50%;
    transform: translateY(-50%);
    width: 10px; height: 10px;
    background-image: var(--droneUrl);
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
  }

  @media (max-width: 1100px) {
    .sector-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .sector-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
