---
const base = import.meta.env.BASE_URL;
const sectors = [
  {
    num: '01', id: 'defense-government',
    titleKey: 'defgov.title', bodyKey: 'defgov.body',
    liKeys: ['defgov.li1','defgov.li2','defgov.li3','defgov.li4','defgov.li5'],
    title: 'Defense & Government',
    body: 'From tactical ISR and encrypted field communications to smart city infrastructure, governance frameworks, and remote education platforms — we equip defense forces and public institutions with technology built for reliability under pressure.',
    li: ['Tactical surveillance & ISR drone integration','Encrypted military-grade communications','Public safety & smart city infrastructure','Governance, risk & compliance frameworks','Remote Education (E-learning)'],
  },
  {
    num: '02', id: 'enterprise',
    titleKey: 'enterprise.title', bodyKey: 'enterprise.body',
    liKeys: ['enterprise.li1','enterprise.li2','enterprise.li3'],
    title: 'Enterprise',
    body: 'We equip enterprises with the tools to stay secure, operationally efficient, and customer-ready — from cybersecurity and fleet management to CRM systems that drive revenue.',
    li: ['SOC onboarding & IAM implementation','Fleet & assets tracking for operations','Customer Relationship Management (CRM) Systems'],
  },
  {
    num: '03', id: 'oilgas',
    titleKey: 'oilgas.title', bodyKey: 'oilgas.body',
    liKeys: ['oilgas.li1','oilgas.li2','oilgas.li3'],
    title: 'Oil & Gas',
    body: 'Remote sites, offshore platforms, and pipeline corridors demand connectivity and safety systems that work without exception.',
    li: ['Satellite & radio connectivity for remote sites','Perimeter intrusion detection for critical assets','Fleet tracking & fuel level monitoring'],
  },
  {
    num: '04', id: 'cellular-mobility',
    titleKey: 'cellular.title', bodyKey: 'cellular.body',
    liKeys: ['cellular.li1','cellular.li2','mobility.li1','mobility.li2'],
    title: 'Cellular & Mobility',
    body: 'We build cellular backhaul infrastructure to extend operator network reach, optimise carrier-grade traffic, and equip logistics sector fleets with real-time tracking and driver safety tools.',
    li: ['Cellular Backhaul','QoS & traffic engineering for carrier-grade networks','Real-time GPS fleet tracking & geofencing','Driver behavior scoring & safety compliance'],
  },
];
---

<div class="container sector-grid-wrap">
  <div class="sector-grid">
    {sectors.map((s) => (
      <div class="sec-card" id={s.id}>
        <span class="sec-card__num" aria-hidden="true">{s.num}</span>
        <div class="sec-card__inner">
          <h3 class="sec-card__title" data-i18n={s.titleKey}>{s.title}</h3>
          <p class="sec-card__body" data-i18n={s.bodyKey}>{s.body}</p>
          <ul class="sec-card__list">
            {s.li.map((text, j) => (
              <li data-i18n={s.liKeys[j]}>{text}</li>
            ))}
          </ul>
        </div>
      </div>
    ))}
  </div>
</div>

<style define:vars={{ droneUrl: `url('${base}icons/drone.svg')` }}>
  .sector-grid-wrap {
    padding-bottom: clamp(48px, 6vw, 80px);
  }

  .sector-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 12px;
  }

  /* Card */
  .sec-card {
    position: relative;
    overflow: hidden;
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--border);
    border-left: 2px solid transparent;
    border-radius: 4px;
    padding: 56px 44px;
    display: flex;
    flex-direction: column;
    gap: 0;
    transition: background 0.2s ease, border-color 0.2s ease;
    cursor: default;
  }
  .sec-card:hover {
    background: rgba(245, 165, 36, 0.05);
    border-left-color: var(--accent);
  }

  /* Watermark number */
  .sec-card__num {
    position: absolute;
    top: -4px; right: 12px;
    font-size: 128px;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.05em;
    color: rgba(245, 165, 36, 0.05);
    pointer-events: none;
    user-select: none;
    transition: color 0.2s ease;
  }
  .sec-card:hover .sec-card__num {
    color: rgba(245, 165, 36, 0.1);
  }

  .sec-card__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .sec-card__title {
    font-size: 26px;
    font-weight: 800;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: .1em;
    line-height: 1;
  }

  .sec-card__body {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.65;
  }

  .sec-card__list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 12px;
    margin-top: 8px;
  }
  .sec-card__list li {
    font-size: 24px;
    color: var(--muted);
    padding-left: 36px; position: relative;
    line-height: 1.45;
  }
  .sec-card__list li::before {
    content: '';
    position: absolute; left: 0; top: 50%;
    transform: translateY(-50%);
    width: 24px; height: 24px;
    background-image: var(--droneUrl);
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
  }

  @media (max-width: 1100px) {
    .sector-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .sector-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
