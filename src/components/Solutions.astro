---
const base = import.meta.env.BASE_URL;

const solutions = [
  {
    id: 'safety',
    slug: 'safety',
    titleKey: 'safety.title', bodyKey: 'safety.body',
    liKeys: ['safety.li1','safety.li2','safety.li3','safety.li4'],
    title: 'Safety & Surveillance',
    body: 'Integrated camera networks, drone monitoring, and analytics platforms that give your security team total situational awareness — day and night, indoors and outdoors.',
    li: ['ISR drone integration & airspace monitoring','Mobile Ad Hoc Networking Systems (MANET)','IP CCTV & thermal imaging networks','AI-assisted video analytics & alerting'],
  },
  {
    id: 'connectivity',
    slug: 'connectivity',
    titleKey: 'connectivity.title', bodyKey: 'connectivity.body',
    liKeys: ['connectivity.li1','connectivity.li2','connectivity.li3','connectivity.li4','connectivity.li5','connectivity.li6'],
    title: 'Connectivity',
    body: 'When your operation cannot afford downtime, we engineer redundant, multi-path connectivity solutions — from satellite links to microwave backhaul — designed for mission-critical environments.',
    li: ['Sites interconnection over Satellite','Satellite on the Move (SOTM)','Satellite on the Pause (SOTP)','Site to site Microwave links','Radio Communication','Network telemetry, SLA monitoring & NOC support'],
  },
  {
    id: 'assets',
    slug: 'assets',
    titleKey: 'assets.title', bodyKey: 'assets.body',
    liKeys: ['assets.li1','assets.li2','assets.li3'],
    title: 'Assets Management',
    body: 'Real-time visibility over vehicles, equipment, and personnel. Reduce fuel waste, prevent theft, and make smarter operational decisions.',
    li: ['GPS fleet tracking & geofencing','Fuel level monitoring & consumption analytics','Driver behavior & safety scoring'],
  },
  {
    id: 'cyber',
    slug: 'cybersecurity',
    titleKey: 'cyber.title', bodyKey: 'cyber.body',
    liKeys: ['cyber.li1','cyber.li2','cyber.li3'],
    title: 'Cybersecurity',
    body: 'From risk assessment to SOC implementation, we help organisations build a security posture that withstands real-world threats in the West African threat landscape.',
    li: ['Vulnerability assessment & penetration testing','SOC onboarding & 24/7 threat monitoring','IAM, zero-trust & compliance frameworks'],
  },
];
---

<section id="what-we-build" aria-labelledby="solutions-heading" class="solutions-section">

  <div class="solutions-heading-wrap container">
    <h2 id="solutions-heading" class="solutions-main-heading">
      What We <span class="text-accent">Build</span>
    </h2>
    <p class="solutions-intro lead" data-i18n="solutions.intro">From defense networks to enterprise infrastructure — we engineer secure, resilient, and always-on IT &amp; telecommunications solutions across every sector we serve.</p>
  </div>

  <div class="container solutions-grid-wrap">
    <div class="solutions-grid">
      {solutions.map((s) => (
        <div class="sol-card" id={s.id}>
          <h3 class="sol-card__title" data-i18n={s.titleKey}>{s.title}</h3>
          <p class="sol-card__body" data-i18n={s.bodyKey}>{s.body}</p>
          <ul class="sol-card__list">
            {s.li.map((text, j) => (
              <li data-i18n={s.liKeys[j]}>{text}</li>
            ))}
          </ul>
          <a class="btn btn--ghost sol-card__cta" href={`${base}solutions/${s.slug}`}>Learn More</a>
        </div>
      ))}
    </div>
  </div>

</section>

<style define:vars={{ droneUrl: `url('${base}icons/drone.svg')` }}>
  .solutions-heading-wrap {
    padding: clamp(40px, 5vw, 64px) 0 clamp(32px, 4vw, 56px);
  }
  .solutions-main-heading {
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 800; letter-spacing: -.04em;
    color: var(--text); text-transform: uppercase; line-height: 1;
  }
  .solutions-intro {
    margin-top: clamp(20px, 2.5vw, 32px);
    font-style: italic;
    color: var(--muted);
  }
  .text-accent { color: var(--accent); }

  .solutions-grid-wrap {
    padding-bottom: clamp(80px, 10vw, 140px);
  }
  .solutions-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  /* Card — mirrors sec-card exactly */
  .sol-card {
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: clamp(24px, 2.5vw, 36px);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.2s ease;
  }
  .sol-card:hover { background: transparent; }

  .sol-card__title {
    font-size: clamp(20px, 1.8vw, 25px);
    font-weight: 800;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: -.02em;
    line-height: 1;
    padding-bottom: 12px;
    border-bottom: 3px solid var(--accent);
  }
  .sol-card__body {
    font-size: clamp(15px, 1.3vw, 17px);
    color: var(--muted);
    line-height: 1.7;
  }
  .sol-card__list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 8px;
    flex: 1;
  }
  .sol-card__list li {
    font-size: clamp(14px, 1.1vw, 16px);
    color: var(--text);
    padding-left: 22px; position: relative;
    line-height: 1.5;
  }
  .sol-card__list li::before {
    content: '';
    position: absolute; left: 0; top: 50%;
    transform: translateY(-50%);
    width: 14px; height: 14px;
    background-image: var(--droneUrl);
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
  }
  .sol-card__cta {
    align-self: flex-start;
    margin-top: 4px;
  }

  @media (max-width: 600px) {
    .solutions-grid { grid-template-columns: 1fr; }
  }
</style>
