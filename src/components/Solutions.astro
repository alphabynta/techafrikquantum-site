---
const base = import.meta.env.BASE_URL;

const solutions = [
  {
    id: 'safety',
    slug: 'safety',
    titleKey: 'safety.title', bodyKey: 'safety.body',
    liKeys: ['safety.li1','safety.li2','safety.li3'],
    title: 'Safety & Surveillance',
    body: 'Integrated camera networks, drone monitoring, and analytics platforms that give your security team total situational awareness — day and night, indoors and outdoors.',
    li: ['IP CCTV & thermal imaging networks','ISR drone integration & airspace monitoring','AI-assisted video analytics & alerting'],
    /* TODO: replace with actual image path, e.g. `${base}images/safety-bg.jpg` */
    img: null,
  },
  {
    id: 'connectivity',
    slug: 'connectivity',
    titleKey: 'connectivity.title', bodyKey: 'connectivity.body',
    liKeys: ['connectivity.li1','connectivity.li2','connectivity.li3'],
    title: 'Critical Connectivity',
    body: 'When your operation cannot afford downtime, we engineer redundant, multi-path connectivity with failover designed for mission-critical environments.',
    li: ['VSAT & LEO satellite links for remote sites','Microwave & LTE hybrid WAN with automatic failover','Network SLA monitoring & proactive NOC support'],
    img: null,
  },
  {
    id: 'assets',
    slug: 'assets',
    titleKey: 'assets.title', bodyKey: 'assets.body',
    liKeys: ['assets.li1','assets.li2','assets.li3'],
    title: 'Assets Management',
    body: 'Real-time visibility over vehicles, equipment, and personnel. Reduce fuel waste, prevent theft, and make smarter operational decisions.',
    li: ['GPS fleet tracking & geofencing','Fuel anti-fraud & consumption analytics','Driver behavior & safety scoring'],
    img: null,
  },
  {
    id: 'ipnetworks',
    slug: 'ip-networks',
    titleKey: 'ipnetworks.title', bodyKey: 'ipnetworks.body',
    liKeys: ['ipnetworks.li1','ipnetworks.li2','ipnetworks.li3'],
    title: 'IP Networks',
    body: 'Enterprise-grade LAN/WAN design, SD-WAN deployment, and network orchestration. Secure, observable, built to grow with your organisation.',
    li: ['LAN/WAN design, deployment & optimisation','SD-WAN & MPLS for multi-site enterprises','Network telemetry, SNMP & flow analytics'],
    img: null,
  },
  {
    id: 'cyber',
    slug: 'cybersecurity',
    titleKey: 'cyber.title', bodyKey: 'cyber.body',
    liKeys: ['cyber.li1','cyber.li2','cyber.li3'],
    title: 'Cybersecurity',
    body: 'From risk assessment to SOC implementation, we help organisations build a security posture that withstands real-world threats in the West African threat landscape.',
    li: ['Vulnerability assessment & penetration testing','SOC onboarding & 24/7 threat monitoring','IAM, zero-trust & compliance frameworks'],
    img: null,
  },
];
---

<section id="solutions" aria-labelledby="solutions-heading" class="solutions-section">

  <div class="solutions-heading-wrap container">
    <h2 id="solutions-heading" class="solutions-main-heading">
      What We <span class="text-accent">Build</span>
    </h2>
  </div>

  {solutions.map((s, i) => (
    <article
      class={`sol-panel${i % 2 === 1 ? ' sol-panel--flip' : ''}`}
      id={s.id}
      style={s.img ? `--panel-img: url('${s.img}')` : ''}
    >
      <div class="sol-panel__bg" aria-hidden="true"></div>
      <div class="sol-panel__overlay" aria-hidden="true"></div>
      <div class="container sol-panel__content">
        <h3 class="sol-panel__title" data-i18n={s.titleKey}>{s.title}</h3>
        <p class="sol-panel__body" data-i18n={s.bodyKey}>{s.body}</p>
        <ul class="sol-panel__list">
          {s.li.map((text, j) => (
            <li data-i18n={s.liKeys[j]}>{text}</li>
          ))}
        </ul>
        <a class="btn btn--ghost sol-panel__cta" href={`${base}solutions/${s.slug}`}>Learn More</a>
      </div>
    </article>
  ))}

</section>

<style>
  .solutions-section {
    /* background transparent — page-bg shows */
  }

  .solutions-heading-wrap {
    padding: clamp(80px, 10vw, 130px) 0 clamp(32px, 4vw, 56px);
  }
  .solutions-main-heading {
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 800; letter-spacing: -.04em;
    color: var(--text); text-transform: uppercase; line-height: 1;
  }
  .text-accent { color: var(--accent); }

  /* ── Full-width panel ── */
  .sol-panel {
    position: relative;
    min-height: 70vh;
    display: flex; align-items: center;
    overflow: hidden;
    border-top: 1px solid var(--border);
  }

  /* Background image — swapped via --panel-img CSS var */
  .sol-panel__bg {
    position: absolute; inset: 0;
    background-image: var(--panel-img, none);
    background-size: cover; background-position: center;
    transition: transform 0.6s ease;
  }
  .sol-panel:hover .sol-panel__bg { transform: scale(1.03); }

  /* Subtle overlay — lets page-bg cycling show through in dark mode. */
  .sol-panel__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      105deg,
      rgba(0,0,0,0.18) 0%,
      rgba(0,0,0,0.08) 55%,
      rgba(0,0,0,0.02) 100%
    );
  }
  .sol-panel--flip .sol-panel__overlay {
    background: linear-gradient(
      -105deg,
      rgba(0,0,0,0.18) 0%,
      rgba(0,0,0,0.08) 55%,
      rgba(0,0,0,0.02) 100%
    );
  }

  /* Amber left accent line */
  .sol-panel::before {
    content: '';
    position: absolute; left: 0; top: 0; bottom: 0;
    width: 4px; background: var(--accent);
    z-index: 2;
  }
  .sol-panel--flip::before { left: auto; right: 0; }

  /* Content */
  .sol-panel__content {
    position: relative; z-index: 2;
    padding-top: clamp(56px, 7vh, 100px);
    padding-bottom: clamp(56px, 7vh, 100px);
    max-width: 780px;
  }
  .sol-panel--flip .sol-panel__content { margin-left: auto; }

  .sol-panel__title {
    font-size: clamp(40px, 6vw, 88px);
    font-weight: 800; color: var(--accent);
    letter-spacing: -.04em; text-transform: uppercase;
    line-height: 0.95; margin-bottom: clamp(20px, 2.5vw, 36px);
  }
  .sol-panel__body {
    font-size: clamp(17px, 1.6vw, 21px);
    color: var(--muted);
    line-height: 1.75; max-width: 580px;
    margin-bottom: clamp(24px, 3vw, 40px);
  }

  .sol-panel__list {
    list-style: none; padding: 0; margin: 0 0 clamp(28px, 3.5vw, 48px);
    display: flex; flex-direction: column; gap: 12px;
  }
  .sol-panel__list li {
    font-size: clamp(15px, 1.4vw, 18px);
    color: var(--text);
    padding-left: 22px; position: relative;
  }
  .sol-panel__list li::before {
    content: '—'; position: absolute; left: 0;
    color: var(--accent); font-weight: 700;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .sol-panel { min-height: 80vw; }
    .sol-panel--flip .sol-panel__content { margin-left: 0; }
    .sol-panel__title { font-size: clamp(36px, 10vw, 60px); }
  }
</style>
