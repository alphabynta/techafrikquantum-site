---
const base = import.meta.env.BASE_URL;
---
<header class="site-header" role="banner">
  <div class="container site-header__inner">
    <a class="logo" href={`${base}`} aria-label="TechAfrik home">
      <svg class="logo-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 116 44" role="img" aria-label="TechAfrik logo">
        <!-- Square box around TECH — always amber -->
        <rect x="0" y="16" width="51" height="20" fill="none" stroke="#f5a524" stroke-width="1.8"/>
        <!-- TECH wire-frame strokes — white on dark, black on light -->
        <g class="logo-tech-letters" fill="none" stroke-width="1.8" stroke-linejoin="miter">
          <!-- T -->
          <line x1="3"  y1="19" x2="13" y2="19"/>
          <line x1="8"  y1="19" x2="8"  y2="34"/>
          <!-- E -->
          <polyline points="25,19 15,19 15,34 25,34"/>
          <line x1="15" y1="26" x2="23" y2="26"/>
          <!-- C -->
          <polyline points="37,19 27,19 27,34 37,34"/>
          <!-- H -->
          <line x1="39" y1="19" x2="39" y2="34"/>
          <line x1="49" y1="19" x2="49" y2="34"/>
          <line x1="39" y1="26" x2="49" y2="26"/>
        </g>
        <!-- AFRIK wire-frame strokes — always amber -->
        <g stroke="#f5a524" stroke-width="1.8" fill="none" stroke-linejoin="miter">
          <!-- A -->
          <polyline points="55,34 60,19 65,34"/>
          <line x1="57" y1="27" x2="63" y2="27"/>
          <!-- F -->
          <polyline points="77,19 67,19 67,34"/>
          <line x1="67" y1="26" x2="75" y2="26"/>
          <!-- R -->
          <polyline points="79,34 79,19 89,19 89,26 79,26"/>
          <line x1="83" y1="26" x2="89" y2="34"/>
          <!-- I -->
          <line x1="96" y1="19" x2="96" y2="34"/>
          <line x1="91" y1="19" x2="101" y2="19"/>
          <line x1="91" y1="34" x2="101" y2="34"/>
          <!-- K -->
          <line x1="103" y1="19" x2="103" y2="34"/>
          <line x1="103" y1="26" x2="113" y2="19"/>
          <line x1="103" y1="26" x2="113" y2="34"/>
        </g>
      </svg>
    </a>
  </div>
</header>

<style>
  .site-header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--nav-scrolled-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    overflow: visible;
  }
  .site-header__inner {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; height: 64px; overflow: visible;
  }
  .logo { display: inline-flex; align-items: center; flex-shrink: 0; }
  .logo-svg {
    width: clamp(110px, 14vw, 155px);
    height: auto;
  }

  /* TECH white on dark, black on light */
  .logo-tech-letters { stroke: #ffffff; }
  :global([data-bg-tone="light"]) .logo-tech-letters { stroke: #000000; }
</style>
