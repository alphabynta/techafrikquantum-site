---
const base = import.meta.env.BASE_URL;
---
<header class="site-header" role="banner">
  <div class="container site-header__inner">
    <a class="logo" href={`${base}`} aria-label="TechAfrik home">
      <svg class="logo-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 150 44" role="img" aria-label="TechAfrik logo">
        <!-- Square box around TECH — always amber -->
        <rect x="0" y="16" width="51" height="20" fill="none" stroke="#f5a524" stroke-width="1.8"/>
        <!-- TECH digital letters -->
        <g class="logo-tech-letters">
          <!-- T -->
          <rect x="3"  y="19" width="10" height="2"/>
          <rect x="7"  y="21" width="2"  height="13"/>
          <!-- E -->
          <rect x="15" y="19" width="2"  height="15"/>
          <rect x="17" y="19" width="8"  height="2"/>
          <rect x="17" y="26" width="6"  height="2"/>
          <rect x="17" y="32" width="8"  height="2"/>
          <!-- C -->
          <rect x="27" y="19" width="2"  height="15"/>
          <rect x="29" y="19" width="8"  height="2"/>
          <rect x="29" y="32" width="8"  height="2"/>
          <!-- H -->
          <rect x="39" y="19" width="2"  height="15"/>
          <rect x="47" y="19" width="2"  height="15"/>
          <rect x="41" y="26" width="6"  height="2"/>
        </g>
        <!-- AFRIK: always amber -->
        <text x="55" y="36"
              font-family="Impact, 'Arial Narrow', 'Franklin Gothic Medium', sans-serif"
              font-size="30" font-weight="900"
              textLength="76" lengthAdjust="spacingAndGlyphs"
              fill="#f5a524">AFRIK</text>
      </svg>
    </a>
  </div>
</header>

<style>
  .site-header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--nav-scrolled-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    overflow: visible;
  }
  .site-header__inner {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; height: 64px; overflow: visible;
  }
  .logo { display: inline-flex; align-items: center; flex-shrink: 0; }
  .logo-svg {
    width: clamp(110px, 14vw, 155px);
    height: auto;
  }

  /* TECH white on dark, black on light */
  .logo-tech-letters { fill: #ffffff; }
  :global([data-bg-tone="light"]) .logo-tech-letters { fill: #000000; }
</style>
