---
const base = import.meta.env.BASE_URL;
---
<header class="site-header" role="banner">
  <div class="container site-header__inner">
    <a class="logo" href={`${base}`} aria-label="TechAfrik home">
      <svg class="logo-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 115 44" role="img" aria-label="TechAfrik logo">
        <!-- Square box around TECH — always amber -->
        <rect x="0" y="16" width="51" height="20" fill="none" stroke="#f5a524" stroke-width="1.8"/>
        <!-- TECH digital letters — white on dark, black on light -->
        <g class="logo-tech-letters">
          <!-- T -->
          <rect x="3"  y="19" width="10" height="2"/>
          <rect x="7"  y="21" width="2"  height="13"/>
          <!-- E -->
          <rect x="15" y="19" width="2"  height="15"/>
          <rect x="17" y="19" width="8"  height="2"/>
          <rect x="17" y="26" width="6"  height="2"/>
          <rect x="17" y="32" width="8"  height="2"/>
          <!-- C -->
          <rect x="27" y="19" width="2"  height="15"/>
          <rect x="29" y="19" width="8"  height="2"/>
          <rect x="29" y="32" width="8"  height="2"/>
          <!-- H -->
          <rect x="39" y="19" width="2"  height="15"/>
          <rect x="47" y="19" width="2"  height="15"/>
          <rect x="41" y="26" width="6"  height="2"/>
        </g>
        <!-- AFRIK wire-frame strokes — smaller, always amber -->
        <g stroke="#f5a524" stroke-width="1.6" fill="none" stroke-linejoin="miter">
          <!-- A -->
          <polyline points="55,34 59,22 63,34"/>
          <line x1="57" y1="29" x2="61" y2="29"/>
          <!-- F -->
          <polyline points="73,22 65,22 65,34"/>
          <line x1="65" y1="28" x2="72" y2="28"/>
          <!-- R -->
          <polyline points="75,34 75,22 83,22 83,28 75,28"/>
          <line x1="79" y1="28" x2="83" y2="34"/>
          <!-- I -->
          <line x1="89" y1="22" x2="89" y2="34"/>
          <line x1="85" y1="22" x2="93" y2="22"/>
          <line x1="85" y1="34" x2="93" y2="34"/>
          <!-- K -->
          <line x1="95" y1="22" x2="95" y2="34"/>
          <line x1="95" y1="28" x2="103" y2="22"/>
          <line x1="95" y1="28" x2="103" y2="34"/>
        </g>
        <!-- Medieval arrow underline — always amber -->
        <!-- Fletching (tail feathers) -->
        <polygon points="55,37 51,33 57,35" fill="#f5a524"/>
        <polygon points="55,37 51,41 57,39" fill="#f5a524"/>
        <!-- Shaft -->
        <line x1="57" y1="37" x2="103" y2="37" stroke="#f5a524" stroke-width="1.6"/>
        <!-- Broadhead with barbs -->
        <polygon points="111,37 105,32 108,35 103,35 103,39 108,39 105,42" fill="#f5a524"/>
      </svg>
    </a>
  </div>
</header>

<style>
  .site-header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--nav-scrolled-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    overflow: visible;
  }
  .site-header__inner {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; height: 64px; overflow: visible;
  }
  .logo { display: inline-flex; align-items: center; flex-shrink: 0; }
  .logo-svg {
    width: clamp(110px, 14vw, 155px);
    height: auto;
  }

  /* TECH white on dark, black on light */
  .logo-tech-letters { fill: #ffffff; }
  :global([data-bg-tone="light"]) .logo-tech-letters { fill: #000000; }
</style>
