---
const base = import.meta.env.BASE_URL;
---
<header class="site-header" role="banner">
  <div class="container site-header__inner">
    <a class="logo" href={`${base}`} aria-label="TechAfrik home">
      <span class="logo-mask" style={`--logo-url: url('${base}logo.png')`} role="img" aria-label="TechAfrik logo"></span>
    </a>

  </div>
</header>

<style>
  .site-header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--nav-scrolled-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    overflow: visible;
  }
  .site-header__inner {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; height: 64px; overflow: visible;
  }
  .logo { display: inline-flex; align-items: center; flex-shrink: 0; }
  :global(body[data-section="what-we-build"]) .logo-mask {
    background-color: #000000;
  }

  .logo-mask {
    display: block;
    width: clamp(144px, 20vw, 208px);
    height: clamp(144px, 20vw, 208px);
    background-color: var(--primary);
    -webkit-mask-image: var(--logo-url);
    mask-image: var(--logo-url);
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
  }
</style>
