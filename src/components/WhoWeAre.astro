---
const base = import.meta.env.BASE_URL;
const sectors = [
  {
    num: '01', id: 'defense-government',
    labelKey: 'defgov.label', titleKey: 'defgov.title', bodyKey: 'defgov.body',
    liKeys: ['defgov.li1','defgov.li2','defgov.li3','defgov.li4','defgov.li5'],
    label: 'Defense & Government', title: 'Defense & Government',
    body: 'From tactical ISR and encrypted field communications to smart city infrastructure, governance frameworks, and remote education platforms — we equip defense forces and public institutions with technology built for reliability under pressure.',
    li: ['Tactical surveillance & ISR drone integration','Encrypted military-grade communications','Public safety & smart city infrastructure','Governance, risk & compliance frameworks','Remote Education (E-learning)'],
  },
  {
    num: '02', id: 'enterprise',
    labelKey: 'enterprise.label', titleKey: 'enterprise.title', bodyKey: 'enterprise.body',
    liKeys: ['enterprise.li1','enterprise.li2','enterprise.li3'],
    label: 'Enterprise', title: 'Enterprise',
    body: 'We equip enterprises with the tools to stay secure, operationally efficient, and customer-ready — from cybersecurity and fleet management to CRM systems that drive revenue.',
    li: ['SOC onboarding & IAM implementation','Fleet & assets tracking for operations','Customer Relationship Management (CRM) Systems'],
  },
  {
    num: '03', id: 'oilgas',
    labelKey: 'oilgas.label', titleKey: 'oilgas.title', bodyKey: 'oilgas.body',
    liKeys: ['oilgas.li1','oilgas.li2','oilgas.li3'],
    label: 'Oil & Gas', title: 'Oil & Gas',
    body: 'Remote sites, offshore platforms, and pipeline corridors demand connectivity and safety systems that work without exception.',
    li: ['Satellite & radio connectivity for remote sites','Perimeter intrusion detection for critical assets','Fleet tracking & fuel anti-fraud systems'],
  },
  {
    num: '04', id: 'cellular-mobility',
    labelKey: 'cellular.label', titleKey: 'cellular.title', bodyKey: 'cellular.body',
    liKeys: ['cellular.li1','mobility.li1','mobility.li2'],
    label: 'Cellular & Mobility', title: 'Cellular & Mobility',
    body: 'We help cellular operators improve network performance while enabling transport operators and national fleets to gain connectivity, reduce costs, and improve safety.',
    li: ['QoS & traffic engineering for carrier-grade networks','Real-time GPS fleet tracking & geofencing','Driver behavior scoring & safety compliance'],
  },
];
---

<section id="who-we-are" aria-labelledby="wwa-heading" class="sectors-section">

  <div class="sectors-heading-wrap container">
    <h2 id="wwa-heading" class="sectors-main-heading">
      Who We <span class="text-accent">Are</span>
    </h2>

    <p class="wwa-intro lead" data-i18n="whoweare.intro">
      TechAfrik is one of West Africa's fastest-growing system integrators — evolved from a specialized fleet management and fuel monitoring company into a multi-platform integrator. Our mission is to empower governments, enterprises, and security forces with world-class technology — with a vision to become West Africa's most trusted partner for defense, security, and connectivity. We are guided by reliability, integrity, excellence, and long-term partnership in everything we deliver.
    </p>
  </div>

  <div class="container sectors-grid-wrap">
    <div class="sectors-grid">
      {sectors.map((s) => (
        <div class="sec-card" id={s.id}>
          <h3 class="sec-card__title" data-i18n={s.titleKey}>{s.title}</h3>
          <p class="sec-card__body" data-i18n={s.bodyKey}>{s.body}</p>
          <ul class="sec-card__list">
            {s.li.map((text, j) => (
              <li data-i18n={s.liKeys[j]}>{text}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

</section>

<style define:vars={{ droneUrl: `url('${base}icons/drone.svg')` }}>
  .sectors-section {
    /* background transparent — page-bg shows */
  }

  .sectors-heading-wrap {
    padding: clamp(80px, 10vw, 130px) 0 clamp(32px, 4vw, 56px);
  }

  .wwa-intro {
    width: 100%;
    max-width: 100%;
    text-align: center;
    font-style: italic;
    color: var(--text);
  }

  .sectors-main-heading {
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 800; letter-spacing: -.04em;
    color: var(--text); text-transform: uppercase; line-height: 1;
    margin-bottom: clamp(20px, 3vw, 36px);
  }
  .text-accent { color: var(--accent); }

  .sectors-grid-wrap {
    padding-bottom: clamp(80px, 10vw, 140px);
  }
  .sectors-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .sec-card {
    border: 1px solid var(--border);
    border-top: 3px solid var(--accent);
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: clamp(24px, 2.5vw, 36px);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.2s ease;
  }
  .sec-card:hover { background: transparent; }
  .sec-card__title {
    font-size: clamp(20px, 1.8vw, 25px);
    font-weight: 800;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: -.02em;
    line-height: 1;
  }
  .sec-card__body {
    font-size: clamp(15px, 1.3vw, 17px);
    color: var(--text);
    line-height: 1.7;
  }
  .sec-card__list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 8px;
  }
  .sec-card__list li {
    font-size: clamp(14px, 1.1vw, 16px);
    color: var(--text);
    padding-left: 22px; position: relative;
    line-height: 1.5;
  }
  .sec-card__list li::before {
    content: '';
    position: absolute; left: 0; top: 50%;
    transform: translateY(-50%);
    width: 14px; height: 14px;
    background-image: var(--droneUrl);
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
  }
  @media (max-width: 600px) {
    .sectors-grid { grid-template-columns: 1fr; }
  }
</style>
