---
const base = import.meta.env.BASE_URL;
const sectors = [
  {
    num: '01', id: 'defense-government',
    labelKey: 'defgov.label', titleKey: 'defgov.title', bodyKey: 'defgov.body',
    liKeys: ['defgov.li1','defgov.li2','defgov.li3','defgov.li4','defgov.li5'],
    label: 'Defense & Government', title: 'Defense & Government',
    body: 'Defense forces and public institutions operate where failure is not an option — in remote terrain, under adversarial conditions, with zero tolerance for downtime. We understand the security requirements, compliance frameworks, and operational pressures unique to this sector.',
    li: ['Armed forces & special operations units','National police, gendarmerie & border security','Smart city & public safety authorities','Government ministries & regulatory bodies','Public education & e-governance institutions'],
  },
  {
    num: '02', id: 'enterprise',
    labelKey: 'enterprise.label', titleKey: 'enterprise.title', bodyKey: 'enterprise.body',
    liKeys: ['enterprise.li1','enterprise.li2','enterprise.li3'],
    label: 'Enterprise', title: 'Enterprise',
    body: 'Businesses across West Africa face growing cyber threats, complex operations, and pressure to serve customers without disruption. We help enterprises stay secure, efficient, and competitive.',
    li: ['Financial institutions, telcos & media companies','Retail, distribution & multi-site operations','Manufacturing & industrial operators'],
  },
  {
    num: '03', id: 'oilgas',
    labelKey: 'oilgas.label', titleKey: 'oilgas.title', bodyKey: 'oilgas.body',
    liKeys: ['oilgas.li1','oilgas.li2','oilgas.li3'],
    label: 'Oil & Gas', title: 'Oil & Gas',
    body: 'Extractive operations run in some of the most hostile and remote environments on the continent — where connectivity gaps, security risks, and asset losses translate directly into production downtime and financial exposure.',
    li: ['Upstream exploration & offshore platforms','Pipeline corridors & midstream infrastructure','Downstream fuel distribution networks'],
  },
  {
    num: '04', id: 'cellular-mobility',
    labelKey: 'cellular.label', titleKey: 'cellular.title', bodyKey: 'cellular.body',
    liKeys: ['cellular.li1','cellular.li2','cellular.li3','cellular.li4'],
    label: 'Cellular & Mobility', title: 'Cellular & Mobility',
    body: 'Mobile network operators need to push coverage further with less infrastructure. Logistics and transport companies need real-time visibility over their fleets. Both demand reliable technology built for Africa\'s operating reality.',
    li: ['Mobile network operators extending rural coverage','Regional & national logistics companies','Public transport authorities','Fuel distribution & tanker fleets'],
  },
];
---

<section id="who-we-are" aria-labelledby="wwa-heading" class="sectors-section">

  <div class="sectors-heading-wrap container">
    <h2 id="wwa-heading" class="sectors-main-heading">
      Who We <span class="text-accent">Are</span>
    </h2>

    <p class="wwa-intro lead" data-i18n="whoweare.intro">
      TechAfrik is one of West Africa's fastest-growing system integrators — evolved from a specialized fleet management and fuel monitoring company into a multi-platform integrator. Our mission is to empower governments, enterprises, and security forces with world-class technology — with a vision to become West Africa's most trusted partner for defense, security, and connectivity. We are guided by reliability, integrity, excellence, and long-term partnership in everything we deliver.
    </p>
  </div>

  <div class="container sectors-grid-wrap">
    <div class="sectors-grid">
      {sectors.map((s) => (
        <div class="sec-card" id={s.id}>
          <h3 class="sec-card__title" data-i18n={s.titleKey}>{s.title}</h3>
          <p class="sec-card__body" data-i18n={s.bodyKey}>{s.body}</p>
          <ul class="sec-card__list">
            {s.li.map((text, j) => (
              <li data-i18n={s.liKeys[j]}>{text}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

</section>

<style define:vars={{ droneUrl: `url('${base}icons/drone.svg')` }}>
  .sectors-section {
    /* background transparent — page-bg shows */
  }

  .sectors-heading-wrap {
    padding: clamp(80px, 10vw, 130px) 0 clamp(32px, 4vw, 56px);
  }

  .wwa-intro {
    width: 100%;
    max-width: 100%;
    text-align: center;
    font-style: italic;
    color: var(--text);
  }

  .sectors-main-heading {
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 800; letter-spacing: -.04em;
    color: var(--text); text-transform: uppercase; line-height: 1;
    margin-bottom: clamp(20px, 3vw, 36px);
  }
  .text-accent { color: var(--accent); }

  .sectors-grid-wrap {
    padding-bottom: clamp(80px, 10vw, 140px);
  }
  .sectors-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .sec-card {
    border: 1px solid var(--border);
    border-top: 3px solid var(--accent);
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: clamp(24px, 2.5vw, 36px);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.2s ease;
  }
  .sec-card:hover { background: transparent; }
  .sec-card__title {
    font-size: clamp(20px, 1.8vw, 25px);
    font-weight: 800;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: -.02em;
    line-height: 1;
  }
  .sec-card__body {
    font-size: clamp(15px, 1.3vw, 17px);
    color: var(--text);
    line-height: 1.7;
  }
  .sec-card__list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 8px;
  }
  .sec-card__list li {
    font-size: clamp(14px, 1.1vw, 16px);
    color: var(--text);
    line-height: 1.5;
  }
  @media (max-width: 600px) {
    .sectors-grid { grid-template-columns: 1fr; }
  }
</style>
